# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=docvisit
DB_USER=your_pg_user
DB_PASSWORD=your_pg_password

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Shorter-lived token issued after OTP verify, before full registration
JWT_TEMP_SECRET=replace_with_another_long_random_secret
JWT_TEMP_EXPIRES_IN=10m

# ── Twilio (OTP SMS) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── OTP ──────────────────────────────────────────────────────────────────────
# OTP validity in seconds
OTP_TTL_SECONDS=300
